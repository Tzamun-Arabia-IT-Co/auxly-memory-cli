# Binaries and executable files
auxly
auxly-cli
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test and coverage artifacts
*.test
*.out
*.prof
*.cov

# Build directories
dist/
build/

# Runtime and temporary directories
.bg-shell/
.gsd/
.tempmediaStorage/
.system_generated/
*.bak

# OS-specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDEs and local configurations
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Local runtime state and research scratch
.auxly/
.tmp-usage-research/

# Local agent dirs + dev tooling — not shipped (the binary writes its own skills
# from internal/skills via `auxly setup`; brand-logos are generator-only inputs
# whose base64 output is already committed in tui/brandlogos.go).
.claude/
.codex/
brand-logos/

# Internal planning/design docs (specs, roadmaps, design drafts) kept locally —
# never shipped in the public repo. User-facing docs live at the repo root
# (README.md, CHANGELOG.md). The whole docs/ tree is internal by policy.
docs/

# Generated workspace agent rules (written by `auxly setup`/`init`, create-if-missing).
# Not source — keep them out of the tree so setup never dirties the repo.
.cursorrules
.antigravityrules
.windsurfrules
.geminirules
.clauderules
.codexrules

# agent-tooling project-id cache (not part of the repo)
cache/

# npm/pip wrapper build artifacts
npm/vendor/
pip/dist/
pip/build/
pip/*.egg-info/
__pycache__/

# Derived semantic index (rebuildable cache, never source of truth)
.index/
**/.index/
*.embeddings.db
